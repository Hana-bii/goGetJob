CONFIG_PATH=configs/config.example.yaml
SERVER_PORT=8080
APP_ENV=dev
APP_NAME=goGetJob
DATABASE_DSN=postgres://gogetjob:gogetjob@postgres:5432/gogetjob?sslmode=disable
REDIS_ADDR=redis:6379
REDIS_DB=0
STORAGE_ENDPOINT=http://storage:9000
STORAGE_BUCKET=interview-guide
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_REGION=us-east-1
AI_DEFAULT_PROVIDER=dashscope
AI_PROVIDER_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
AI_PROVIDER_DASHSCOPE_API_KEY=
AI_PROVIDER_DASHSCOPE_MODEL=qwen-plus
AI_PROVIDER_LMSTUDIO_BASE_URL=http://localhost:1234
AI_PROVIDER_LMSTUDIO_API_KEY=lm-studio
AI_PROVIDER_LMSTUDIO_MODEL=qwen2.5-7b-instruct
RAG_REWRITE_ENABLED=true
RAG_SHORT_QUERY_LENGTH=4
RAG_TOPK_SHORT=20
RAG_TOPK_MEDIUM=12
RAG_TOPK_LONG=8
RAG_MIN_SCORE_SHORT=0.18
RAG_MIN_SCORE_DEFAULT=0.28
INTERVIEW_FOLLOW_UP_COUNT=1
INTERVIEW_EVALUATION_BATCH_SIZE=8
VOICE_LLM_PROVIDER=dashscope
VOICE_TTS_DEFAULT_VOICE=siyue
VOICE_TTS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
VOICE_TTS_MODEL=qwen3-tts-flash-realtime
VOICE_TTS_API_KEY=
VOICE_TTS_VOICE=Cherry
VOICE_TTS_FORMAT=pcm
VOICE_TTS_SAMPLE_RATE=24000
VOICE_TTS_MODE=commit
VOICE_TTS_LANGUAGE_TYPE=Chinese
VOICE_TTS_SPEECH_RATE=1.0
VOICE_TTS_VOLUME=60
VOICE_ASR_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
VOICE_ASR_MODEL=qwen3-asr-flash-realtime
VOICE_ASR_API_KEY=
VOICE_ASR_LANGUAGE=zh
VOICE_ASR_FORMAT=pcm
VOICE_ASR_SAMPLE_RATE=16000
VOICE_ASR_ENABLE_TURN_DETECTION=true
VOICE_ASR_TURN_DETECTION_TYPE=server_vad
VOICE_ASR_TURN_DETECTION_THRESHOLD=0
VOICE_ASR_TURN_DETECTION_SILENCE_MS=2000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:80
POSTGRES_USER=gogetjob
POSTGRES_PASSWORD=gogetjob
POSTGRES_DB=gogetjob
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
BACKEND_PORT=8080
FRONTEND_PORT=3000
